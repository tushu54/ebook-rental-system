<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/deep_orange"
    android:orientation="vertical"
    tools:context=".MainActivity">


    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <RelativeLayout
            android:id="@+id/linearColumnellipsesix"
            style="@style/groupStyle_deep_orange"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/linearLoginScreen"
                style="@style/groupStyle_deep_orange"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <RelativeLayout
                    android:id="@+id/frameStackemail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start">

                    <RelativeLayout
                        android:id="@+id/frameStackellipsesix"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|start"
                        android:layout_marginBottom="@dimen/_10px"
                        android:orientation="vertical">


                        <ImageView
                            android:id="@+id/imageEllipseSix"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/_300px"
                            android:layout_gravity="start"
                            android:layout_marginEnd="@dimen/_30px"
                            android:scaleType="fitXY"
                            android:src="@drawable/img_ellipse_login"
                            tools:ignore="ContentDescription"
                            tools:src="@drawable/img_ellipse_login" />

                        <LinearLayout
                            android:id="@+id/linearWelcomeBack"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="top|start"
                            android:layout_marginStart="@dimen/_30px"
                            android:layout_marginTop="@dimen/_70px"
                            android:layout_marginEnd="@dimen/_30px"
                            android:layout_marginBottom="@dimen/_30px"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/txtWelcomeBack"
                                style="@style/txt_OpenSansExtraBold"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:ellipsize="end"
                                android:singleLine="true"
                                android:text="@string/lbl_welcome_back"
                                android:textColor="@color/gray"
                                android:textSize="@dimen/_30sp"
                                tools:text="@string/lbl_welcome_back" />

                            <TextView
                                android:id="@+id/txtLetsLoginA"
                                style="@style/txt_OpenSansRomanBold"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/_5px"
                                android:layout_marginEnd="@dimen/_10px"
                                android:ellipsize="end"
                                android:lineSpacingExtra="@dimen/_1px"
                                android:singleLine="true"
                                android:text="@string/lbl_let_s_log_in_a"
                                android:textColor="@color/gray_trans_99"
                                android:textSize="@dimen/_16sp"
                                tools:text="@string/lbl_let_s_log_in_a" />

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/linearLoginFild"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_below="@+id/linearWelcomeBack"
                            android:layout_marginStart="@dimen/_30px"
                            android:layout_marginTop="@dimen/_50px"
                            android:layout_marginEnd="@dimen/_30px"
                            android:orientation="vertical">

                            <EditText
                                android:id="@+id/edtEmail"
                                style="@style/edtBoxRoundedOutline"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@drawable/rectangle_bg_white_border"
                                android:ellipsize="end"
                                android:hint="@string/lbl_email"
                                android:inputType="textEmailAddress"
                                android:lineSpacingExtra="@dimen/_1px"
                                android:paddingStart="@dimen/_20px"
                                android:paddingTop="@dimen/_18px"
                                android:paddingEnd="@dimen/_30px"
                                android:paddingBottom="@dimen/_18px"
                                android:singleLine="true"
                                android:textColorHint="@color/gray_edt_hint_text"
                                android:textCursorDrawable="@drawable/cursor"
                                tools:ignore="Autofill" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/_15px"
                                android:textCursorDrawable="@drawable/cursor"
                                app:boxStrokeWidth="0dp"
                                app:boxStrokeWidthFocused="0dp"
                                app:hintAnimationEnabled="false"
                                app:hintEnabled="false"
                                app:passwordToggleEnabled="true">

                                <EditText
                                    android:id="@+id/edtPass"
                                    style="@style/edtBoxRoundedOutline"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/rectangle_bg_white_border"
                                    android:ellipsize="end"
                                    android:hint="@string/lbl_pass"
                                    android:inputType="textPassword"
                                    android:lineSpacingExtra="@dimen/_1px"
                                    android:paddingStart="@dimen/_20px"
                                    android:paddingTop="@dimen/_18px"
                                    android:paddingEnd="@dimen/_30px"
                                    android:paddingBottom="@dimen/_18px"
                                    android:singleLine="true"
                                    android:textColorHint="@color/gray_edt_hint_text"
                                    android:textCursorDrawable="@drawable/cursor"
                                    tools:ignore="Autofill" />
                            </com.google.android.material.textfield.TextInputLayout>

                        </LinearLayout>
                    </RelativeLayout>


                </RelativeLayout>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnLogIn"
                    style="@style/txtOpenSansRomanBold"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_30px"
                    android:layout_marginTop="@dimen/_20px"
                    android:layout_marginEnd="@dimen/_30px"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:lineSpacingExtra="@dimen/_1px"
                    android:paddingStart="@dimen/_30px"
                    android:paddingTop="@dimen/_16px"
                    android:paddingEnd="@dimen/_30px"
                    android:paddingBottom="@dimen/_16px"
                    android:singleLine="true"
                    android:text="@string/lbl_log_in"
                    android:textAllCaps="false"
                    tools:text="@string/lbl_log_in" />

                <RelativeLayout
                    android:id="@+id/frameStackellipseeight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="bottom">

                    <ImageView
                        android:id="@+id/imageEllipseEight"
                        android:layout_width="@dimen/_250px"
                        android:layout_height="@dimen/_120px"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentBottom="true"
                        android:layout_marginEnd="-50dp"
                        android:layout_marginBottom="-50dp"
                        android:scaleType="fitXY"
                        android:src="@drawable/img_ellipse_login_bottom"
                        tools:ignore="ContentDescription"
                        tools:src="@drawable/img_ellipse_login_bottom" />

                </RelativeLayout>
            </LinearLayout>

        </RelativeLayout>
    </androidx.core.widget.NestedScrollView>


</LinearLayout>