<?xml version="1.0" encoding="UTF-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <RelativeLayout
        android:id="@+id/llBook"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_marginStart="@dimen/_8px"
        android:layout_marginEnd="@dimen/_8px"
        android:layout_marginTop="@dimen/_12px"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <com.github.siyamed.shapeimageview.mask.PorterShapeImageView
            android:id="@+id/ivBook"
            android:layout_width="135dp"
            android:layout_height="185dp"
            android:layout_alignParentTop="true"
            android:layout_gravity="start"
            android:layout_marginStart="@dimen/_10px"
            android:layout_marginTop="@dimen/_10px"
            android:scaleType="fitXY"
            android:src="@drawable/placeholder_portable"
            app:siShape="@drawable/image_book_list"
            tools:ignore="ContentDescription"
            tools:src="@drawable/placeholder_portable" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_10px"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="19dp"
            android:layout_toEndOf="@+id/ivBook"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvBookName"
                style="@style/txt_OpenSansRomanBold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/_10px"
                android:text="@string/app_name"
                android:includeFontPadding="false"
                android:textColor="@color/gray_2"
                android:textSize="@dimen/_16sp"
                tools:text="@string/app_name" />

            <TextView
                android:id="@+id/tvByName"
                style="@style/txtOpenSansRomanSemiBold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_5px"
                android:layout_marginEnd="@dimen/_10px"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="@color/home_by_author"
                android:textSize="@dimen/_14sp"
                tools:text="@string/app_name" />
            <LinearLayout
                android:id="@+id/linearRating"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_8px"
                android:layout_marginEnd="@dimen/_10px"
                android:layout_above="@+id/tvBookPrice"
                android:layout_marginBottom="@dimen/_1px"
                android:gravity="start"
                android:orientation="horizontal">


                <TextView
                    android:id="@+id/tvBookStar"
                    style="@style/txtOpenSansRomanSemiBold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginStart="@dimen/_5px"
                    android:layout_marginTop="@dimen/_1px"
                    android:layout_marginBottom="@dimen/_1px"
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:textColor="@color/home_by_author"
                    android:textSize="@dimen/_15sp"
                    android:text="txID: " />



                <TextView
                    android:id="@+id/tvTxValue"
                    style="@style/txtOpenSansRomanSemiBold"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginStart="@dimen/_5px"
                    android:layout_marginTop="@dimen/_1px"
                    android:layout_marginBottom="@dimen/_1px"
                    android:layout_weight="0.29"
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:textColor="@color/home_by_author"
                    android:textSize="@dimen/_15sp"
                    tools:text="0.0" />

            </LinearLayout>
            <TextView
                android:id="@+id/tvBookPrice"
                style="@style/txtOpenSansRomanSemiBold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_8px"
                android:ellipsize="end"
                android:singleLine="true"
                android:paddingStart="@dimen/_8px"
                android:paddingTop="@dimen/_3px"
                android:paddingEnd="@dimen/_8px"
                android:paddingBottom="@dimen/_3px"
                android:background="@drawable/paid_detail_box"
                android:layout_alignParentBottom="true"
                android:textColor="@color/white"
                android:textSize="@dimen/_15sp"
                tools:text="$0.0" />
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_8px"
                    android:layout_marginEnd="@dimen/_10px"
                    android:layout_marginBottom="@dimen/_1px"
                    android:gravity="end"
                    android:padding="@dimen/_5px"
                    android:orientation="horizontal">

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/Approve"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginStart="@dimen/_15px"
                        android:text="Appove"
                        android:textAllCaps="false"
                        style="@style/Approve"/>


<!--                    <androidx.appcompat.widget.AppCompatButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reject"
                        android:textAllCaps="false"
                        android:layout_marginStart="@dimen/_15px"
                        style="@style/Reject"/>-->



                </LinearLayout>


            </RelativeLayout>
        </LinearLayout>

    </RelativeLayout>
</RelativeLayout>